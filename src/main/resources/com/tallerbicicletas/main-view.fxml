<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.tallerbicicletas.MainController">

    <left>
        <VBox spacing="10" prefWidth="200" style="-fx-padding: 15;">
            <Label text="MENÚ" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
            <Button text="Registrar Cliente" onAction="#mostrarRegistrarCliente"/>
            <Button text="Registrar Bicicleta" onAction="#mostrarRegistrarBicicleta"/>
            <Button text="Registrar Mecánico" onAction="#mostrarRegistrarMecanico"/>
            <Button text="Nueva Orden" onAction="#mostrarNuevaOrden"/>
            <Button text="Historial Bicicleta" onAction="#mostrarHistorial"/>
            <Button text="Órdenes por Fecha" onAction="#mostrarOrdenesFecha"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contenidoCentral"/>
    </center>

</BorderPane>